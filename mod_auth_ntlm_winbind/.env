PACKAGE_NAME=libapache2-mod-auth-ntlm-winbind
PACKAGE_LICENSE=Apache-2.0
PACKAGE_URL=http://adldap.sourceforge.net/wiki/doku.php?id=mod_auth_ntlm_winbind
MAINTAINER=Ubuntu Developers <ubuntu-devel-discuss@lists.ubuntu.com>
ARCH_DEB=amd64
DOCKER_IMAGE=apache_mod_auth_ntlm_winbind_build
SOURCE_ROOT=bx-mod_auth_ntlm_winbind-0.0.0-0.el9.src
SOURCE_DIR=bx-mod_auth_ntlm_winbind
MODULE_NAME=mod_auth_ntlm_winbind.so
BUILD_DEPS=apache2 apache2-dev autoconf build-essential patch
PACKAGE_VERSION=0.0.0
ITERATION=1
DESCRIPTION=apache2 module for NTLM authentication against Winbind
DESCRIPTION+= The mod_auth_ntlm_winbind module provides authentication and
DESCRIPTION+= authorisation over the web against a Microsoft Windows NT/2000/XP/etc or
DESCRIPTION+= Samba Domain Controller using Samba's winbind daemon running on the
DESCRIPTION+= same machine Apache is running on.
DESCRIPTION+= .
DESCRIPTION+= If you're considering using this module, you should be aware that NTLM
DESCRIPTION+= isn't regarded as very secure by modern standards - even Microsoft no longer
DESCRIPTION+= recommends its use - and where possible, you probably want to use gssapi with
DESCRIPTION+= negotiate auth over https instead (see Debian package
DESCRIPTION+= libapache2-mod-auth-gssapi).
DEPENDS=libc6 (>= 2.14), winbind, libnss-winbind, libpam-winbind, krb5-user
CONFIG_FILE=etc/apache2/mods-available/auth_ntlm_winbind.load

DEBIAN_12_BASE_IMAGE=debian:12
DEBIAN_12_DISTRO=debian
DEBIAN_12_VERSION_CODENAME=bookworm

DEBIAN_13_BASE_IMAGE=debian:trixie-slim
DEBIAN_13_DISTRO=debian
DEBIAN_13_VERSION_CODENAME=trixie

UBUNTU_24_04_BASE_IMAGE=ubuntu:24.04
UBUNTU_24_04_DISTRO=ubuntu
UBUNTU_24_04_VERSION_CODENAME=noble
