PACKAGE_NAME=libnginx-mod-http-zip
PACKAGE_LICENSE=bsd3
PACKAGE_URL=https://github.com/evanmiller/mod_zip
SOURCE_REPO_URL=https://github.com/evanmiller/mod_zip
SOURCE_DIR=mod_zip
MAINTAINER=YogSottot <7411302+YogSottot@users.noreply.github.com>
ARCH_DEB=amd64
DOCKER_IMAGE=nginx_mod_zip_build
MODULE_NAME=ngx_http_zip_module.so
MODULE_CONF_NAME=mod-http-zip.conf
MODULE_CONF_CONTENT=load_module modules/ngx_http_zip_module.so;
DESCRIPTION=mod_zip assembles ZIP archives dynamically. It can stream component files from upstream servers with nginx's native proxying code, so that the process never takes up more than a few KB of RAM at a time, even while assembling archives that are (potentially) gigabytes in size.
PACKAGE_VERSION=1.3.0
MOD_ZIP_VERSION=4aa963c27318530ec7a0c2939bc6ffdc06ffdda2
ITERATION=2.gbp4aa963c

DEBIAN_12_BASE_IMAGE=debian:12
DEBIAN_12_DISTRO=debian
DEBIAN_12_VERSION_CODENAME=bookworm
DEBIAN_12_NGINX_VERSION=1.22.1
DEBIAN_12_NGINX_ABI=nginx-abi-1.22.1-7
DEBIAN_12_LIBC_DEPENDS=libc6 (>= 2.4)
DEBIAN_12_BUILD_DEPS=ca-certificates wget git build-essential libpcre3-dev zlib1g-dev liblzma-dev liblz4-dev libzip-dev unzip uuid-dev

DEBIAN_13_BASE_IMAGE=debian:trixie-slim
DEBIAN_13_DISTRO=debian
DEBIAN_13_VERSION_CODENAME=trixie
DEBIAN_13_NGINX_VERSION=1.26.3
DEBIAN_13_NGINX_ABI=nginx-abi-1.26.3-1
DEBIAN_13_LIBC_DEPENDS=libc6 (>= 2.4)
DEBIAN_13_BUILD_DEPS=ca-certificates wget git build-essential libpcre2-dev zlib1g-dev liblzma-dev liblz4-dev libzip-dev unzip uuid-dev

