#!/bin/sh
set -e
# Helper: safely add or remove a user from a group with syslog logging
# Usage: manage_user_group <add|remove> <user> <group>
manage_user_group() {
    action="$1"
    user="$2"
    group="$3"

    # Ensure both user and group exist
    if ! getent passwd "$user" >/dev/null 2>&1; then
        logger -p daemon.info -t libapache2-mod-auth-ntlm-winbind "User '$user' does not exist, skipping $action $group"
        return 0
    fi
    if ! getent group "$group" >/dev/null 2>&1; then
        logger -p daemon.info -t libapache2-mod-auth-ntlm-winbind "Group '$group' does not exist, skipping $action $user"
        return 0
    fi

    case "$action" in
        add)
            if ! id -nG "$user" | grep -qw "$group"; then
                adduser --quiet "$user" "$group" >/dev/null 2>&1 || true
                logger -p daemon.info -t libapache2-mod-auth-ntlm-winbind "Added user '$user' to group '$group'"
            else
                logger -p daemon.info -t libapache2-mod-auth-ntlm-winbind "User '$user' already in group '$group', skipping"
            fi
            ;;
        remove)
            if id -nG "$user" | grep -qw "$group"; then
                deluser --quiet "$user" "$group" >/dev/null 2>&1 || true
                logger -p daemon.info -t libapache2-mod-auth-ntlm-winbind "Removed user '$user' from group '$group'"
            else
                logger -p daemon.info -t libapache2-mod-auth-ntlm-winbind "User '$user' not in group '$group', skipping"
            fi
            ;;
        *)
            logger -p daemon.info -t libapache2-mod-auth-ntlm-winbind "Unknown action '$action' for user '$user' and group '$group'"
            return 1
            ;;
    esac
}

# Automatically added by dh_apache2/UNDECLARED
if true; then
	if [ -e /usr/share/apache2/apache2-maintscript-helper ] ; then
		. /usr/share/apache2/apache2-maintscript-helper
		for conf in auth_ntlm_winbind  ; do
			apache2_invoke enmod $conf  
		done
		if [ -f /etc/apache2/envvars ]; then
            . /etc/apache2/envvars
        fi
        manage_user_group add "$APACHE_RUN_USER" winbindd_priv
	fi
fi
# End automatically added section

