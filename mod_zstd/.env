UBUNTU_24_04_LIBC_DEPENDS=libc6 (>= 2.17)
UBUNTU_24_04_BUILD_DEPS=ca-certificates wget git build-essential libpcre3-dev zlib1g-dev liblzma-dev liblz4-dev

