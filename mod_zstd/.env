PACKAGE_NAME=libnginx-mod-http-zstd
PACKAGE_LICENSE=bsd3
PACKAGE_URL=https://github.com/tokers/zstd-nginx-module
SOURCE_REPO_URL=https://github.com/tokers/zstd-nginx-module
SOURCE_DIR=mod_zstd
MAINTAINER=YogSottot <7411302+YogSottot@users.noreply.github.com>
ARCH_DEB=amd64
DOCKER_IMAGE=nginx_mod_zstd_build
MODULE_NAMES=ngx_http_zstd_filter_module.so ngx_http_zstd_static_module.so
MODULE_CONF_NAME=mod-http-zstd.conf
MODULE_CONF_CONTENT=load_module modules/ngx_http_zstd_filter_module.so;\nload_module modules/ngx_http_zstd_static_module.so;
DESCRIPTION=NGINX module for ZSTD compression
PACKAGE_VERSION=0.1.1
MOD_ZSTD_VERSION=057a7d339af1111d04b5a9ac5ae9b0250d17cd94
ZSTD_VERSION=1.5.7
ITERATION=2.gbp057a7d3

DEBIAN_12_BASE_IMAGE=debian:12
DEBIAN_12_DISTRO=debian
DEBIAN_12_VERSION_CODENAME=bookworm
DEBIAN_12_LIBC_DEPENDS=libc6 (>= 2.4)
DEBIAN_12_BUILD_DEPS=ca-certificates wget git build-essential libpcre3-dev zlib1g-dev liblzma-dev liblz4-dev libzip-dev unzip uuid-dev

DEBIAN_13_BASE_IMAGE=debian:trixie-slim
DEBIAN_13_DISTRO=debian
DEBIAN_13_VERSION_CODENAME=trixie
DEBIAN_13_LIBC_DEPENDS=libc6 (>= 2.4)
DEBIAN_13_BUILD_DEPS=ca-certificates wget git build-essential libpcre2-dev zlib1g-dev liblzma-dev liblz4-dev libzip-dev unzip uuid-dev

