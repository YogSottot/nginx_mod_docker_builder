PACKAGE_NAME=libnginx-mod-http-ntlm
PACKAGE_LICENSE=bsd3
PACKAGE_URL=https://github.com/gabihodoroaga/nginx-ntlm-module
SOURCE_REPO_URL=https://github.com/gabihodoroaga/nginx-ntlm-module
SOURCE_DIR=mod_ntlm
MAINTAINER=YogSottot <7411302+YogSottot@users.noreply.github.com>
ARCH_DEB=amd64
DOCKER_IMAGE=nginx_mod_ntlm_build
MODULE_NAME=ngx_http_upstream_ntlm_module.so
MODULE_CONF_NAME=mod-http-ntlm.conf
MODULE_CONF_CONTENT=load_module modules/ngx_http_upstream_ntlm_module.so;
DESCRIPTION=The NTLM module allows proxying requests with NTLM Authentication. The upstream connection is bound to the client connection once the client sends a request with the "Authorization" header field value starting with "Negotiate" or "NTLM". Further client requests will be proxied through the same upstream connection, keeping the authentication context.
PACKAGE_VERSION=1.19.3
MOD_NTLM_VERSION=3da77b0cb30e517dfee01d7e7f7d649144d24051
ITERATION=1.gbp3da77b0

DEBIAN_12_BASE_IMAGE=debian:12
DEBIAN_12_DISTRO=debian
DEBIAN_12_VERSION_CODENAME=bookworm
DEBIAN_12_LIBC_DEPENDS=libc6 (>= 2.4)
DEBIAN_12_BUILD_DEPS=ca-certificates wget git build-essential libpcre3-dev zlib1g-dev liblzma-dev liblz4-dev libzip-dev unzip uuid-dev

DEBIAN_13_BASE_IMAGE=debian:trixie-slim
DEBIAN_13_DISTRO=debian
DEBIAN_13_VERSION_CODENAME=trixie
DEBIAN_13_LIBC_DEPENDS=libc6 (>= 2.4)
DEBIAN_13_BUILD_DEPS=ca-certificates wget git build-essential libpcre2-dev zlib1g-dev liblzma-dev liblz4-dev libzip-dev unzip uuid-dev

